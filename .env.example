# ROI Online Credentials
ROI_EMAIL=your_email_here
ROI_PASSWORD=your_password_here

# Gmail Settings (IMAP)
# Use the mailbox address you want to monitor.
# Generate a Gmail app password and make sure IMAP is enabled for that mailbox.
GMAIL_ADDRESS=your_gmail_address_here
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Email Filter
TRIGGER_EMAIL_SENDER=noreply@staff.nl

# For iCloud Calendar:
# 1. Go to https://appleid.apple.com/account/manage
# 2. Generate an app-specific password
# 3. Use your Apple ID email as username
# 4. Use the app-specific password (not your regular password)
CALDAV_URL=https://caldav.icloud.com
CALDAV_USERNAME=your_apple_id@icloud.com
CALDAV_PASSWORD=your_app_specific_password_here
CALDAV_CALENDAR_NAME=Rooster
